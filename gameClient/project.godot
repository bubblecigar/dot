; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Blank2DGames"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6")
features=PackedStringArray("4.2")

[autoload]

ClientRpc="*res://rpc/receive_from_server.gd"
ServerRpc="*res://rpc/emit_to_server.gd"
StateStore="*res://stores/state_store.gd"
LocalStore="*res://stores/local_store.gd"
SceneManager="*res://managers/scene_manager.gd"
AuthManager="*res://managers/auth_manager.gd"
SessionFlowManager="*res://managers/session_flow_manager.gd"

[rendering]

textures/canvas_textures/default_texture_repeat=1
renderer/rendering_method.mobile="forward_plus"
textures/vram_compression/import_etc2_astc=true
